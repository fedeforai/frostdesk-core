{
  "name": "frostdesk-core",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "description": "Core repository for Frostdesk project",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter '@frostdesk/db' --filter '@frostdesk/api' -r run build",
    "dev": "pnpm --filter '@frostdesk/db' --filter '@frostdesk/api' -r --parallel run dev",
    "dev:instructor": "pnpm --filter @frostdesk/instructor dev",
    "dev:admin": "pnpm --filter @frostdesk/admin dev",
    "dev:web": "pnpm --filter @frostdesk/web dev",
    "test": "pnpm --filter @frostdesk/db test && pnpm --filter @frostdesk/api test",
    "verify:pnpm": "bash scripts/verify_repo.sh",
    "verify": "bash scripts/pre-deploy-check.sh",
    "verify:code": "pnpm knip",
    "verify:security": "pnpm audit --audit-level=high",
    "verify:types": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm --filter @frostdesk/admin lint && pnpm --filter @frostdesk/instructor lint",
    "lint:fix": "pnpm --filter @frostdesk/admin lint --fix && pnpm --filter @frostdesk/instructor lint --fix",
    "deploy": "bash scripts/deploy.sh",
    "deploy:dry": "DRY_RUN=true bash scripts/deploy.sh",
    "build:api": "pnpm --filter @frostdesk/api build",
    "start:api": "node apps/api/dist/index.js",
    "build:instructor": "pnpm --filter @frostdesk/instructor build",
    "start:instructor": "pnpm --filter @frostdesk/instructor start",
    "build:admin": "pnpm --filter @frostdesk/admin build",
    "start:admin": "pnpm --filter @frostdesk/admin start",
    "build:web": "pnpm --filter @frostdesk/web build",
    "start:web": "pnpm --filter @frostdesk/web start",
    "dev:landing": "pnpm --filter @frostdesk/landing dev",
    "build:landing": "pnpm --filter @frostdesk/landing build",
    "start:landing": "pnpm --filter @frostdesk/landing start"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.6.1",
    "knip": "^5.86.0",
    "resolve-pkg-maps": "^1.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "minimatch": ">=10.2.3",
      "serialize-javascript": ">=7.0.3"
    }
  }
}